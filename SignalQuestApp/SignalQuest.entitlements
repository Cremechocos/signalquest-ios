<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Environnement APNs piloté par configuration : `development` en Debug/Staging,
	     `production` en Release (cf. SQ_APS_ENVIRONMENT dans Config/*.xcconfig).
	     Xcode substitue la variable lors de la signature. Nécessite la capacité
	     « Push Notifications » activée sur l'App ID fr.signalquest.ios. -->
	<key>aps-environment</key>
	<string>$(SQ_APS_ENVIRONMENT)</string>
	<!-- Requis par NEHotspotNetwork.fetchCurrent (lecture du SSID Wi-Fi pour les
	     speedtests). Nécessite la capacité « Access WiFi Information » activée sur
	     l'App ID, ET une autorisation CoreLocation accordée au runtime. -->
	<key>com.apple.developer.networking.wifi-info</key>
	<true/>
</dict>
</plist>
