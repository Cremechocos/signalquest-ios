<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Type importé pour les exports NetMonster (.ntm) : sans extension système,
	     on le déclare conforme à public.plain-text pour qu'il soit proposé par le
	     sélecteur de fichiers de l'import de logs radio. -->
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>fr.signalquest.ntm</string>
			<key>UTTypeDescription</key>
			<string>Export NetMonster</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.plain-text</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>ntm</string>
				</array>
			</dict>
		</dict>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Épinglage TLS déclaratif (App Transport Security). On épingle la SPKI des
	     RACINES ISRG (Let's Encrypt) — X1 + X2 en secours — au lieu d'un certificat
	     feuille ou d'un intermédiaire (R12/R13…), qui tournent fréquemment et
	     casseraient l'app. signalquest.fr ET speedtest.signalquest.fr chaînent vers
	     ISRG Root X1. CloudFront (CDN speedtest) n'est PAS épinglé (AC Amazon).
	     IMPORTANT OPS : si le backend migre d'autorité de certification, mettre à
	     jour ces empreintes AVANT le déploiement du nouveau certificat. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSPinnedDomains</key>
		<dict>
			<key>signalquest.fr</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSPinnedCAIdentities</key>
				<array>
					<dict>
						<key>SPKI-SHA256-BASE64</key>
						<string>C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</string>
					</dict>
					<dict>
						<key>SPKI-SHA256-BASE64</key>
						<string>diGVwiVYbubAI3RW4hB9xU8e/CH2GnkuvVFZE8zmgzI=</string>
					</dict>
				</array>
			</dict>
		</dict>
	</dict>
	<key>CFBundleDisplayName</key>
	<string>$(SQ_DISPLAY_NAME)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>SignalQuest utilise la caméra uniquement pendant les appels vidéo que tu démarres ou acceptes.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>SignalQuest utilise Face ID pour verrouiller l&apos;app et déverrouiller ta messagerie chiffrée.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SignalQuest utilise ta position, si tu l&apos;autorises, pour placer tes speedtests et contributions sur la carte, suivre un Drive Test (y compris écran verrouillé) et, si tu l&apos;actives, partager ta position en direct avec tes amis.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>SignalQuest utilise le micro uniquement pendant les appels audio ou vidéo que tu démarres ou acceptes.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SignalQuest peut importer une photo choisie pour contribuer aux sites antennes.</string>
	<key>SQ_API_BASE_URL</key>
	<string>$(SQ_API_BASE_URL)</string>
	<key>SQ_APP_GROUP</key>
	<string>$(SQ_APP_GROUP)</string>
	<key>SQ_APP_BASE_URL</key>
	<string>$(SQ_APP_BASE_URL)</string>
	<key>SQ_DEBUG_LOGS</key>
	<string>$(SQ_DEBUG_LOGS)</string>
	<key>SQ_ENVIRONMENT</key>
	<string>$(SQ_ENVIRONMENT)</string>
	<key>SQ_URL_SCHEME</key>
	<string>$(SQ_URL_SCHEME)</string>
	<key>UIAppFonts</key>
	<array>
		<string>Figtree-Regular.ttf</string>
		<string>Figtree-Medium.ttf</string>
		<string>Figtree-SemiBold.ttf</string>
		<string>Figtree-Bold.ttf</string>
		<string>BricolageGrotesque-SemiBold.ttf</string>
		<string>BricolageGrotesque-Bold.ttf</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>voip</string>
		<string>remote-notification</string>
		<!-- Mode rafale continu (drive test) : le suivi de localisation maintient
		     l'app active écran verrouillé pour enchaîner les speedtests. -->
		<string>location</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>BackgroundPrimary</string>
		<key>UIImageName</key>
		<string>LaunchLogo</string>
	</dict>
	<key>UIRequiresFullScreen</key>
	<false/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER).deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(SQ_URL_SCHEME)</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
